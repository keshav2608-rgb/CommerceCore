# ---------- Global / Docker Compose ----------
COMPOSE_PROJECT_NAME=commercecore

# ---------- PostgreSQL (order-payment-service) ----------
POSTGRES_DB=commercecore_orders
POSTGRES_USER=commercecore
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# ---------- MongoDB (catalog-cart-service) ----------
MONGO_INITDB_ROOT_USERNAME=commercecore
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo
MONGO_PORT=27017
MONGO_DB=commercecore_catalog

# ---------- Redis (catalog-cart-service) ----------
REDIS_PORT=6379

# ---------- catalog-cart-service ----------
CATALOG_SERVICE_PORT=4000
MONGO_URI=mongodb://commercecore:change_me_mongo@mongo:27017/commercecore_catalog?authSource=admin
REDIS_URL=redis://redis:6379

# ---------- order-payment-service ----------
ORDER_SERVICE_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/commercecore_orders
SPRING_DATASOURCE_USERNAME=commercecore
SPRING_DATASOURCE_PASSWORD=change_me_postgres

# JWT
JWT_SECRET=aUdialRlQjdnOTY5Y1NvSkJrYzNoUmV4Q1JkYmNZ
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# Shared secret for service-to-service calls (order-payment-service -> catalog-cart-service)
# Month-1 simplification — see services/order-payment-service/.../CatalogServiceClient.java
INTERNAL_SERVICE_SECRET=aUdialRlQjdnOTY5Y1NvSkJrYzNoUmV4Q1JkYmNZ

# Cart TTL (seconds) — how long an abandoned cart survives in Redis
CART_TTL_SECONDS=604800

# ---------- Frontend (Week 3) ----------
# React dev server origin allowed to call order-payment-service directly
# (see SecurityConfig.java). Must match the port Vite actually runs on
# (frontend/vite.config.ts pins it to 5173).
FRONTEND_ORIGIN=http://localhost:5173

# ---------- Gateway ----------
GATEWAY_PORT=8081
